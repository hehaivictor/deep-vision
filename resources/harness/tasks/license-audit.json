{
  "name": "license-audit",
  "description": "License 状态、运行时开关与账号绑定审计，默认只读检查，不进入写操作。",
  "risk_level": "medium",
  "doctor_profile": "auto",
  "guardrails_suite": "minimal",
  "smoke_suite": "minimal",
  "strict_doctor": false,
  "docs": [
    "docs/agent/admin-ops.md"
  ],
  "playbook": {
    "output": "docs/agent/playbooks/license-audit.md",
    "title": "License 审计",
    "summary": "把 License 校验开关、活跃批次和账号绑定检查收口到固定只读流程，先看 observe 与运行态，再决定是否进入高风险写操作。",
    "when_to_use": [
      "用户反馈无法进入业务链路，怀疑是 License 缺失、过期或运行时开关异常",
      "需要核对当前 License 校验开关、批次分布、绑定账号和即将到期情况",
      "需要在不改数据的前提下先完成审计"
    ],
    "command_blocks": [
      {
        "commands": [
          "python3 scripts/agent_observe.py --profile auto",
          "python3 scripts/license_manager.py enforcement-status --json",
          "python3 scripts/license_manager.py list --status active --json",
          "python3 scripts/agent_harness.py --task license-audit --profile auto --artifact-dir artifacts/harness-runs",
          "python3 scripts/agent_eval.py --scenario access-boundaries --artifact-dir artifacts/harness-eval"
        ]
      },
      {
        "intro": "如需看某个账号的绑定情况，再补：",
        "commands": [
          "python3 scripts/license_manager.py list --bound-account 13700000000 --json"
        ]
      }
    ],
    "artifact_files": [
      "artifacts/harness-runs/latest.json",
      "对应 run 目录下的 doctor.json",
      "对应 run 目录下的 workflow.json",
      "对应 run 目录下的 guardrails.json",
      "artifacts/harness-eval/latest.json",
      "对应 evaluator run 目录下的 access-boundaries.json"
    ],
    "focus_points": [
      "LICENSE_ENFORCEMENT_ENABLED 当前运行态和默认值是否一致",
      "活跃 License 批次、绑定账号和时间窗状态是否异常",
      "access-boundaries 是否仍保持匿名写拦截和分享只读边界",
      "doctor / observe 是否提示 mock 短信、实例隔离或配置来源风险"
    ],
    "manual_confirmations": [
      "enforcement-set --enabled true/false",
      "enforcement-set --sync-default",
      "revoke、extend、批量生成或批量撤销 License",
      "将演示环境的 mock 行为带入生产风格配置"
    ]
  },
  "workflow": {
    "mode": "verify_first",
    "steps": [
      {
        "id": "observe",
        "title": "先观察运行态与最近趋势",
        "command": "python3 scripts/agent_observe.py --profile auto"
      },
      {
        "id": "enforcement-status",
        "title": "读取当前 License 校验开关",
        "command": "python3 scripts/license_manager.py enforcement-status --json"
      },
      {
        "id": "active-licenses",
        "title": "查看活跃 License 列表",
        "command": "python3 scripts/license_manager.py list --status active --json"
      },
      {
        "id": "verify",
        "title": "跑 License 门禁与激活专项回归",
        "executor": "unittest",
        "quiet": true,
        "cases": [
          {
            "test_id": "tests.test_security_regression.SecurityRegressionTests.test_license_gate_blocks_business_routes_but_allows_auth_and_license_endpoints",
            "label": "License 门禁边界"
          },
          {
            "test_id": "tests.test_api_comprehensive.ComprehensiveApiTests.test_license_activation_and_status_summary",
            "label": "License 激活与状态汇总"
          },
          {
            "test_id": "tests.test_api_comprehensive.ComprehensiveApiTests.test_admin_license_routes_require_valid_license_even_when_gate_disabled",
            "label": "管理员 License 接口门禁"
          }
        ]
      }
    ]
  }
}
